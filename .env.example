PORT=3000
SMS_PROVIDER=twilio

# Twilio settings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# MSG91 settings (optional)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_COUNTRY=91

# Development fallback: set true to log OTP to server console when SMS config is absent
ALLOW_CONSOLE_OTP=false
